generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TransactionType {
  BUY
  SELL
}

model User {
  id           String        @id @default(uuid())
  username     String        @unique
  email        String        @unique
  password     String
  balance      Float         @default(100000)
  createdAt    DateTime      @default(now())

  portfolios   Portfolio[]
  transactions Transaction[]
}

model Portfolio {
  id            String   @id @default(uuid())
  userId        String
  stockSymbol   String
  quantity      Int
  avgBuyPrice   Float
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([stockSymbol])
}

model Transaction {
  id           String   @id @default(uuid())
  userId       String
  stockSymbol  String
  quantity     Int
  price        Float
  total        Float
  type         TransactionType
  profitLoss   Float?
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([stockSymbol])
}

model StockCache {
  id          String   @id @default(uuid())
  symbol      String   @unique
  price       Float
  updatedAt   DateTime @updatedAt
}